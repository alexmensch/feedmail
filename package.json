{
  "name": "feedmail",
  "version": "0.4.0",
  "description": "RSS-to-email microservice on Cloudflare Workers. Monitor feeds, manage subscribers, send newsletters.",
  "type": "module",
  "license": "AGPL-3.0",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler d1 migrations apply feedmail --remote && wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply feedmail --remote",
    "db:migrate:local": "wrangler d1 migrations apply feedmail --local",
    "build:check": "wrangler deploy --dry-run --outdir dist",
    "pretest": "node scripts/precompile-templates.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:coverage": "node scripts/precompile-templates.mjs",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "fast-xml-parser": "^5.4.1",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18",
    "wrangler": "^4.14.4"
  },
  "packageManager": "pnpm@10.30.2"
}
