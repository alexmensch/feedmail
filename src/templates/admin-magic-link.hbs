<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
</head>
<body>
  <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="max-width:600px;margin:0 auto;font-family:sans-serif;">
    <tr>
      <td style="padding:40px 20px;">
        <h1 style="font-size:24px;margin:0 0 20px;">Sign in to feedmail admin</h1>
        <p style="font-size:16px;line-height:1.5;color:#333;">Click the link below to sign in to your feedmail admin console:</p>
        <table cellpadding="0" cellspacing="0" role="presentation" style="margin:30px 0;">
          <tr>
            <td style="background:#0066cc;border-radius:4px;">
              <a href="{{verifyUrl}}" style="display:inline-block;padding:12px 24px;color:#fff;text-decoration:none;font-size:16px;">Sign in</a>
            </td>
          </tr>
        </table>
        <p style="font-size:14px;line-height:1.5;color:#666;">Or copy and paste this URL into your browser:</p>
        <p style="font-size:14px;line-height:1.5;color:#666;word-break:break-all;">{{verifyUrl}}</p>
        <p style="font-size:14px;line-height:1.5;color:#666;">This link expires in 15 minutes.</p>
        <p style="font-size:14px;line-height:1.5;color:#999;margin-top:30px;">If you didn't request this, you can safely ignore this email.</p>
      </td>
    </tr>
  </table>
</body>
</html>
