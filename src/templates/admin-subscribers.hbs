{{#> admin-layout pageTitle="Subscribers" activePage="subscribers"}}
{{#*inline "content"}}

<h1>Subscribers</h1>

{{#if error}}
<div class="feedback" data-variant="error" role="alert">{{error}}</div>
{{/if}}

{{#if hasChannels}}
<form method="GET" action="/admin/subscribers"
  hx-get="/admin/subscribers" hx-target="#subscriber-table" hx-swap="innerHTML" hx-push-url="true">
  <div class="cluster">
    <div class="form-field">
      <label for="channelId">Channel</label>
      <select id="channelId" name="channelId">
        <option value="">Select a channel</option>
        {{#each channels}}
        <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.siteName}} ({{this.id}})</option>
        {{/each}}
      </select>
    </div>

    <div class="form-field">
      <label for="status">Status</label>
      <select id="status" name="status">
        <option value="" {{#unless selectedStatus}}selected{{/unless}}>All</option>
        <option value="pending" {{#if (eq selectedStatus "pending")}}selected{{/if}}>Pending</option>
        <option value="verified" {{#if (eq selectedStatus "verified")}}selected{{/if}}>Verified</option>
        <option value="unsubscribed" {{#if (eq selectedStatus "unsubscribed")}}selected{{/if}}>Unsubscribed</option>
      </select>
    </div>

    <button type="submit">Filter</button>
    <span class="htmx-indicator"><span class="loading-spinner"></span></span>
  </div>
</form>

<div id="subscriber-table">
{{#if showTable}}
  {{#if hasSubscribers}}
  <table class="table">
    <thead>
      <tr><th>Email</th><th>Channel</th><th>Status</th><th>Subscribed</th></tr>
    </thead>
    <tbody>
      {{#each subscribers}}
      <tr>
        <td>{{this.email}}</td>
        <td>{{../selectedChannelId}}</td>
        <td>{{this.status}}</td>
        <td>{{formatDate this.created_at}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <p class="text-muted">No subscribers match the current filters.</p>
  {{/if}}
{{else}}
  {{#unless selectedChannelId}}
  <p class="text-muted">Select a channel to view subscribers.</p>
  {{/unless}}
{{/if}}
</div>

{{else}}
<p class="text-muted">No channels available. <a href="/admin/channels">Create a channel</a> first.</p>
{{/if}}

{{/inline}}
{{/admin-layout}}