<!DOCTYPE html>
<html lang="en">
<head>
  {{> admin-head}}
  <title>Subscribers — feedmail admin</title>
</head>
<body>
  <h1>Subscribers</h1>
  {{> admin-nav}}

  {{#if error}}
  <div class="error">{{error}}</div>
  {{/if}}

  {{#if hasChannels}}
  <form method="GET" action="/admin/subscribers" style="margin-bottom: 20px;">
    <label for="channelId"><strong>Channel:</strong></label>
    <select id="channelId" name="channelId">
      <option value="">Select a channel</option>
      {{#each channels}}
      <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.siteName}} ({{this.id}})</option>
      {{/each}}
    </select>

    <label for="status" style="margin-left: 12px;"><strong>Status:</strong></label>
    <select id="status" name="status">
      <option value="" {{#unless selectedStatus}}selected{{/unless}}>All</option>
      <option value="pending" {{#if (eq selectedStatus "pending")}}selected{{/if}}>Pending</option>
      <option value="verified" {{#if (eq selectedStatus "verified")}}selected{{/if}}>Verified</option>
      <option value="unsubscribed" {{#if (eq selectedStatus "unsubscribed")}}selected{{/if}}>Unsubscribed</option>
    </select>

    <button type="submit" style="margin-left: 8px;">Filter</button>
  </form>

  {{#if showTable}}
    {{#if hasSubscribers}}
    <table>
      <thead>
        <tr><th>Email</th><th>Channel</th><th>Status</th><th>Subscribed</th></tr>
      </thead>
      <tbody>
        {{#each subscribers}}
        <tr>
          <td>{{this.email}}</td>
          <td>{{../selectedChannelId}}</td>
          <td>{{this.status}}</td>
          <td>{{formatDate this.created_at}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    {{else}}
    <p>No subscribers match the current filters.</p>
    {{/if}}
  {{else}}
    {{#unless selectedChannelId}}
    <p>Select a channel to view subscribers.</p>
    {{/unless}}
  {{/if}}
  {{else}}
  <p>No channels available. <a href="/admin/channels">Create a channel</a> first.</p>
  {{/if}}
</body>
</html>
