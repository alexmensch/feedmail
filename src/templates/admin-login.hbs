<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Sign in — feedmail admin</title>
</head>
<body>
  <h1>feedmail admin</h1>
  <p>Enter your email address to receive a sign-in link.</p>

  {{#if errorMessage}}
  <p role="alert"><strong>{{errorMessage}}</strong></p>
  {{/if}}

  <form method="POST" action="/admin/login">
    <label for="email">Email address</label><br>
    <input type="email" id="email" name="email" required autofocus><br><br>
    {{#if redirect}}
    <input type="hidden" name="redirect" value="{{redirect}}">
    {{/if}}
    <button type="submit">Send sign-in link</button>
  </form>
</body>
</html>
