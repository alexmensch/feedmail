{{#if error}}
<div class="feedback feedback--error" role="alert">{{error}}</div>
{{/if}}

{{#if success}}
<div class="feedback feedback--success" role="status">{{success}}</div>
{{/if}}

<form method="POST" action="/admin/channels/{{channel.id}}" id="channel-form"
  hx-post="/admin/channels/{{channel.id}}" hx-target="#form-result" hx-swap="innerHTML">

  {{> admin-channel-form-body isEdit=true}}

  <button type="submit" name="action" value="save">Save Changes</button>
  <span class="htmx-indicator"><span class="loading-spinner"></span></span>
</form>