<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" lang="en">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Confirm your subscription to {{siteName}}</title>
  <!--[if mso]>
  <noscript>
    <xml>
      <o:OfficeDocumentSettings>
        <o:PixelsPerInch>96</o:PixelsPerInch>
      </o:OfficeDocumentSettings>
    </xml>
  </noscript>
  <![endif]-->
</head>
<body style="margin: 0; padding: 0; background-color: #faf9f7; -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%;">
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color: #faf9f7;">
    <tr>
      <td align="center" style="padding: 24px 16px;">
        <!--[if (gte mso 9)|(IE)]>
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600"><tr><td>
        <![endif]-->
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width: 600px;">
          <!-- Header -->
          <tr>
            <td style="padding: 24px 0 20px 0; border-bottom: 2px solid #0c6faa;">
              <a href="{{siteUrl}}" style="font-family: Inter, Helvetica, Arial, sans-serif; font-size: 18px; font-weight: 700; color: #0c6faa; text-decoration: none;">{{siteName}}</a>
            </td>
          </tr>
          <!-- Heading -->
          <tr>
            <td style="padding: 32px 0 0 0;">
              <h1 style="margin: 0 0 16px 0; font-family: Inter, Helvetica, Arial, sans-serif; font-size: 24px; font-weight: 700; line-height: 1.3; color: #212a3d;">Confirm your subscription</h1>
            </td>
          </tr>
          <!-- Body text -->
          <tr>
            <td style="padding: 0 0 24px 0;">
              <p style="margin: 0; font-family: Georgia, 'Source Serif 4', serif; font-size: 17px; line-height: 1.7; color: #212a3d;">Click the link below to confirm your email address and start receiving updates.</p>
            </td>
          </tr>
          <!-- CTA Button -->
          <tr>
            <td style="padding: 0 0 24px 0;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="background-color: #0c6faa; border-radius: 6px;">
                    <a href="{{{verifyUrl}}}" style="display: inline-block; padding: 14px 32px; font-family: Inter, Helvetica, Arial, sans-serif; font-size: 16px; font-weight: 600; color: #ffffff; text-decoration: none;">Confirm subscription</a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- Expiry notice -->
          <tr>
            <td style="padding: 0 0 8px 0;">
              <p style="margin: 0; font-family: Georgia, 'Source Serif 4', serif; font-size: 15px; line-height: 1.5; color: #465270;">This link expires in 24 hours.</p>
            </td>
          </tr>
          <!-- Ignore notice -->
          <tr>
            <td style="padding: 0 0 32px 0;">
              <p style="margin: 0; font-family: Georgia, 'Source Serif 4', serif; font-size: 15px; line-height: 1.5; color: #465270;">If you didn't request this, you can safely ignore this email.</p>
            </td>
          </tr>
          <!-- Footer -->
          <tr>
            <td style="padding: 24px 0 0 0; border-top: 1px solid #d1cfc9;">
              {{> email-footer}}
            </td>
          </tr>
        </table>
        <!--[if (gte mso 9)|(IE)]>
        </td></tr></table>
        <![endif]-->
      </td>
    </tr>
  </table>
</body>
</html>
