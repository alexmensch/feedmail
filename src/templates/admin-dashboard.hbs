{{#> admin-layout pageTitle="Dashboard" activePage="dashboard"}}
{{#*inline "content"}}

<h1>Dashboard</h1>

{{#if error}}
<div class="feedback" data-variant="error" role="alert">{{error}}</div>
{{/if}}

{{#if success}}
<div class="feedback" data-variant="success" role="status">{{success}}</div>
{{/if}}

{{#if showPasskeyPrompt}}
<div class="passkey-prompt">
  <p><strong>Secure your account with a passkey.</strong> Sign in with a single tap using your device's biometrics or PIN instead of waiting for a magic link email.</p>
  <p><a href="/admin/settings">Register a passkey</a> | <a href="/admin?dismissed=passkey">Dismiss</a></p>
</div>
{{/if}}

<div id="send-feedback"></div>

{{#if hasChannels}}
<form method="POST" action="/admin/send"
  hx-post="/admin/send" hx-target="#send-feedback" hx-swap="innerHTML">
  <button type="submit">Check all feeds</button>
  <span class="htmx-indicator"><span class="loading-spinner"></span></span>
</form>

{{#each channels}}
<div class="card stack" data-gap="xs">
  <h2><a href="/admin/channels/{{this.id}}">{{this.siteName}}</a></h2>
  {{#if this.error}}
  <div class="feedback" data-variant="error">{{this.error}}</div>
  {{else}}
  <table class="table">
    <tr><th>Verified</th><td>{{this.subscribers.verified}}</td></tr>
    <tr><th>Pending</th><td>{{this.subscribers.pending}}</td></tr>
    <tr><th>Unsubscribed</th><td>{{this.subscribers.unsubscribed}}</td></tr>
    <tr><th>Total subscribers</th><td>{{this.subscribers.total}}</td></tr>
    <tr><th>Items sent</th><td>{{this.sentItems.total}}</td></tr>
  </table>
  {{/if}}
</div>
{{/each}}
{{else}}
<p class="text-muted">No channels configured. <a href="/admin/channels/new">Create your first channel</a> to get started.</p>
{{/if}}

{{/inline}}
{{/admin-layout}}