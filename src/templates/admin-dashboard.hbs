<!DOCTYPE html>
<html lang="en">
<head>
  {{> admin-head}}
  <title>Dashboard — feedmail admin</title>
  <style>
    .passkey-prompt { background: #f0f6ff; padding: 12px 16px; border-radius: 4px; margin-bottom: 20px; }
  </style>
</head>
<body>
  <h1>feedmail admin</h1>
  {{> admin-nav}}

  {{#if error}}
  <div class="error">{{error}}</div>
  {{/if}}

  {{#if success}}
  <div class="success">{{success}}</div>
  {{/if}}

  {{#if showPasskeyPrompt}}
  <div class="passkey-prompt">
    <p><strong>Secure your account with a passkey.</strong> Sign in with a single tap using your device's biometrics or PIN instead of waiting for a magic link email.</p>
    <p><a href="/admin/settings">Register a passkey</a> | <a href="/admin?dismissed=passkey">Dismiss</a></p>
  </div>
  {{/if}}

  {{#if hasChannels}}
  <form method="POST" action="/admin/send" style="margin-bottom: 20px;">
    <button type="submit">Check all feeds</button>
  </form>

  {{#each channels}}
  <h2><a href="/admin/channels/{{this.id}}">{{this.siteName}}</a></h2>
  {{#if this.error}}
  <p class="error">{{this.error}}</p>
  {{else}}
  <table>
    <tr><th>Verified</th><td>{{this.subscribers.verified}}</td></tr>
    <tr><th>Pending</th><td>{{this.subscribers.pending}}</td></tr>
    <tr><th>Unsubscribed</th><td>{{this.subscribers.unsubscribed}}</td></tr>
    <tr><th>Total subscribers</th><td>{{this.subscribers.total}}</td></tr>
    <tr><th>Items sent</th><td>{{this.sentItems.total}}</td></tr>
  </table>
  {{/if}}
  {{/each}}
  {{else}}
  <p>No channels configured. <a href="/admin/channels">Create your first channel</a> to get started.</p>
  {{/if}}
</body>
</html>
